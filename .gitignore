# Build / scratch artifacts (never commit)
__pycache__/
*.pyc
img/raw-*.png
raw-*.png
_mk_*.py

# Cloudflare Worker local cache
worker/.wrangler/
node_modules/

# Editor / OS / tooling
.playwright-mcp/
.DS_Store
Thumbs.db

# Secrets & credentials (never commit)
.env
.env.*
!.env.example
token_*.json
*credentials*.json
cookies.txt

# Temp / scratch
*.tmp
*.bak

# Internal meeting notes / feedback (never publish to the public Pages site)
feedback/

# Stray root-level slide-deck / PDF artifacts (hosted on Google Drive; do not commit).
# Anchored to root so tracked PDFs under sample-data/ are unaffected.
/*.pdf
